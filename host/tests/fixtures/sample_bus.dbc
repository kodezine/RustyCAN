CM_ BO_ 48 "keep alive";
CM_ BO_ 50 "@CMD";
CM_ SG_ 50 BPFP_CMD_M "
 1-FPB_1_SELF_TEST_RES: Return the result of the self-test
 2-FPB_1_SOFTWARE_VERSION: Return the current installed software version, build nr and CRC sum
 3-FPB_1_UPDATE: Go into update mode
 5-FPB_1_NORMAL: 
 6-FPB_1_SET_ENC_TYPE: Set the encodertype of the Pumps (0: 200, 1: 400, 2: 500, 3: 1000)
 7-FPB_1_AUTO_DETECT_ENC: Autodetect the current encoder type
 10-FPB_1_GET_HASH: Get FW Hash
 85-FPB_1_SW_RESET: Softreset of the MCU
 86-FPB_1_SLEEP: Go into deep sleep
 87-FPB_1_SYSTEM_TEST: Go into system test mode";
CM_ BO_ 56 "I'm alive";
CM_ BO_ 59 "Acknowledge of 0x030
@RSP";
CM_ BO_ 96 "keep alive";
CM_ BO_ 104 "I'm alive";
CM_ SG_ 105 HSP_ABS_POSITION_M "@IST @CAL";

CM_ SG_ 122 ADU_PRESSURE_M "@FLOAT";
CM_ BO_ 144 "keep alive
@CMD";
CM_ SG_ 144 SPB_CMD_M "
 1-SPB_SELF_TEST_RES: Return the result of the self-test
 2-SPB_SOFTWARE_VERSION: Return the current installed software version, build nr and CRC sum
 3-SPB_UPDATE: Go into update mode
 5-SPB_NORMAL: 
 6-SPB_ADC_RESET: Reset ADCs
 10-SPB_GET_HASH: Get FW Hash
 85-SPB_SW_RESET: Softreset of the MCU
 86-SPB_SLEEP: Go into deep sleep
 87-SPB_SYSTEM_TEST: Go into system test mode";
CM_ BO_ 152 "I'm alive";
CM_ SG_ 154 FIL_ADC_VAL_M "@RB @IST @CAL";
